        private void LoadCategories()
        {
            foreach (var category in categories.Keys)
            {
                cmbCategory.Items.Add(category);
            }
            
            if (cmbCategory.Items.Count > 0)
                cmbCategory.SelectedIndex = 0;
        }
        
        private void CmbCategory_SelectionChanged(object sender, System.Windows.Controls.SelectionChangedEventArgs e)
        {
            if (cmbCategory.SelectedItem == null) return;
            
            string selectedCategory = cmbCategory.SelectedItem.ToString();
            
            cmbFrom.Items.Clear();
            cmbTo.Items.Clear();
            
            foreach (var unit in categories[selectedCategory])
            {
                cmbFrom.Items.Add(unit);
                cmbTo.Items.Add(unit);
            }
            
            if (cmbFrom.Items.Count > 0)
            {
                cmbFrom.SelectedIndex = 0;
                cmbTo.SelectedIndex = 1 % cmbTo.Items.Count;
            }
        }
        
        private async void BtnConvert_Click(object sender, RoutedEventArgs e)
        {
            // Показать ProgressBar
            progressBar.Visibility = Visibility.Visible;
            progressBar.IsIndeterminate = true;
            
            // Имитация загрузки для анимации
            await System.Threading.Tasks.Task.Delay(100);
            
            try
            {
                // Проверка ввода
                if (string.IsNullOrWhiteSpace(txtValue.Text))
                {
                    lblResult.Text = "Ошибка: Введите значение!";
                    return;
                }
                
                if (!double.TryParse(txtValue.Text, out double value))
                {
                    lblResult.Text = "Ошибка: Введите корректное число!";
                    return;
                }
                
                if (cmbCategory.SelectedItem == null)
                {
                    lblResult.Text = "Ошибка: Выберите категорию!";
                    return;
                }
                
                if (cmbFrom.SelectedItem == null || cmbTo.SelectedItem == null)
                {
                    lblResult.Text = "Ошибка: Выберите единицы измерения!";
                    return;
                }
                
                string category = cmbCategory.SelectedItem.ToString();
                Unit fromUnit = (Unit)cmbFrom.SelectedItem;
                Unit toUnit = (Unit)cmbTo.SelectedItem;
                
                double result;
                
                // Особый случай для температуры (нелинейная)
                if (category == "Температура")
                {
                    result = ConvertTemperature(value, fromUnit.Name, toUnit.Name);
                }
                else
                {
                    // Стандартная конвертация через базовую единицу
                    double inBase = value * fromUnit.ToBaseFactor;
                    result = inBase / toUnit.ToBaseFactor;
                }
                
                lblResult.Text = $"Результат: {result:F6} {toUnit.Name.Split('(')[0].Trim()}";
            }
            catch (Exception ex)
            {
                lblResult.Text = $"Ошибка: {ex.Message}";
            }
            finally
            {
                // Скрыть ProgressBar
                progressBar.IsIndeterminate = false;
                progressBar.Visibility = Visibility.Collapsed;
            }
        }
        
        private double ConvertTemperature(double value, string fromUnit, string toUnit)
        {
            // Сначала переводим в Кельвины
            double kelvin;
            
            if (fromUnit.Contains("Кельвин"))
                kelvin = value;
            else if (fromUnit.Contains("Цельсий"))
                kelvin = value + 273.15;
            else if (fromUnit.Contains("Фаренгейт"))
                kelvin = (value - 32) * 5 / 9 + 273.15;
            else
                throw new Exception("Неизвестная единица температуры");
            
            // Переводим из Кельвинов в целевую единицу
            if (toUnit.Contains("Кельвин"))
                return kelvin;
            else if (toUnit.Contains("Цельсий"))
                return kelvin - 273.15;
            else if (toUnit.Contains("Фаренгейт"))
                return (kelvin - 273.15) * 9 / 5 + 32;
            else
                throw new Exception("Неизвестная единица температуры");
        }
