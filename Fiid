            public string Name { get; set; }
            public double ToBaseFactor { get; set; } // Коэффициент перевода в базовую единицу СИ
            
            public Unit(string name, double toBaseFactor)
            {
                Name = name;
                ToBaseFactor = toBaseFactor;
            }
            
