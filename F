<Window x:Class="SiConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Конвертер единиц СИ" 
        Height="800" Width="1200" 
        WindowStartupLocation="CenterScreen"
        Background="#2A2A2A">
    
    <Grid>
        <!-- Фоновое изображение с затемнением -->
        <Grid>
            <Image Source="background.jpg" Stretch="UniformToFill"/>
            <Rectangle Fill="#80000000"/>
        </Grid>
        
        <!-- Основной контент -->
        <Grid Margin="50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Заголовок -->
            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                       Text="Конвертер единиц СИ" 
                       FontFamily="Times New Roman" 
                       FontSize="48" 
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,30"/>
            
            <!-- Выбор категории -->
            <TextBlock Grid.Row="1" Grid.Column="0" 
                       Text="Категория:" 
                       FontFamily="Times New Roman" 
                       FontSize="36" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10"/>
            
            <ComboBox x:Name="cmbCategory" 
                      Grid.Row="1" Grid.Column="1" 
                      FontFamily="Times New Roman" 
                      FontSize="36" 
                      Height="50"
                      Margin="10"
                      SelectionChanged="CmbCategory_SelectionChanged"/>
            
            <!-- Исходная единица -->
            <TextBlock Grid.Row="2" Grid.Column="0" 
                       Text="Из:" 
                       FontFamily="Times New Roman" 
                       FontSize="36" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10"/>
            
            <ComboBox x:Name="cmbFrom" 
                      Grid.Row="2" Grid.Column="1" 
                      FontFamily="Times New Roman" 
                      FontSize="36" 
                      Height="50"
                      Margin="10"/>
            
            <!-- Целевая единица -->
            <TextBlock Grid.Row="3" Grid.Column="0" 
                       Text="В:" 
                       FontFamily="Times New Roman" 
                       FontSize="36" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10"/>
            
            <ComboBox x:Name="cmbTo" 
                      Grid.Row="3" Grid.Column="1" 
                      FontFamily="Times New Roman" 
                      FontSize="36" 
                      Height="50"
                      Margin="10"/>
            
            <!-- Значение -->
            <TextBlock Grid.Row="4" Grid.Column="0" 
                       Text="Значение:" 
                       FontFamily="Times New Roman" 
                       FontSize="36" 
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="10"/>
            
            <TextBox x:Name="txtValue" 
                     Grid.Row="4" Grid.Column="1" 
                     FontFamily="Times New Roman" 
                     FontSize="36" 
                     Height="50"
                     Margin="10"
                     Background="White"/>
            
            <!-- Кнопка конвертации -->
            <Button x:Name="btnConvert" 
                    Grid.Row="5" Grid.ColumnSpan="2" 
                    Content="Конвертировать" 
                    FontFamily="Times New Roman" 
                    FontSize="36" 
                    Height="70"
                    Width="300"
                    Margin="10"
                    HorizontalAlignment="Center"
                    Background="#4CAF50"
                    Foreground="White"
                    Click="BtnConvert_Click"/>
            
            <!-- Результат -->
            <TextBlock x:Name="lblResult" 
                       Grid.Row="6" Grid.ColumnSpan="2" 
                       FontFamily="Times New Roman" 
                       FontSize="36" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       Margin="10"
                       Text="Результат: "/>
            
            <!-- ProgressBar -->
            <ProgressBar x:Name="progressBar" 
                         Grid.Row="6" Grid.ColumnSpan="2" 
                         Height="10"
                         VerticalAlignment="Bottom"
                         Margin="10"
                         Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
