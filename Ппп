using System;

class Program
{
    static void Main()
    {
        // Вычисляем точные значения
        double result1 = 21.0 / 13.0; // Точное значение 21/13
        double approx1 = 1.62; // Приближённое значение
        double absError1 = Math.Abs(result1 - approx1); // Абсолютная погрешность

        double result2 = Math.Sqrt(63); // Точное значение √63
        double approx2 = 7.94; // Приближённое значение
        double absError2 = Math.Abs(result2 - approx2); // Абсолютная погрешность

        Console.WriteLine($"Точное значение 21/13: {result1}, приближённое: {approx1}, погрешность: {absError1}");
        Console.WriteLine($"Точное значение √63: {result2}, приближённое: {approx2}, погрешность: {absError2}");

        if (absError1 < absError2)
            Console.WriteLine("Равенство 21/13 = 1.62 точнее.");
        else
            Console.WriteLine("Равенство √63 = 7.94 точнее.");
    }
}
